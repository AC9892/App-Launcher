{
  "name": "antc_home_launcher",
  "version": "1.3.1",
  "private": true,
  "description": "Standalone launcher app for external tools and apps",
  "main": "./main.js",
  "scripts": {
    "build:portable": "node ./scripts/build-portable.js",
    "build:installer": "electron-builder --win nsis",
    "start": "electron .",
    "test": "node ./test/launcher.test.js"
  },
  "build": {
    "appId": "com.antc.home-launcher",
    "productName": "App Launcher",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "Confg/**/*",
      "!Confg/temp-debug.log",
      "index.html",
      "main.js",
      "package.json",
      "preload.js",
      "README.md",
      "renderer.js",
      "src/**/*",
      "styles.css"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "AppLauncher-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "App Launcher"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12"
  }
}
